# Copy this file's content into your Streamlit Community Cloud app's
# "Secrets" settings (Settings -> Secrets). Do NOT commit a real secrets.toml
# file to GitHub - it is already excluded via .gitignore.

# A GitHub Personal Access Token with "repo" access.
# Used by this app to:
#   1) read/write profiles.json in your GitHub repo
#   2) be embedded in the cron-job.org job so it can trigger your
#      GitHub Actions workflow via the repository_dispatch API
GH_TOKEN = "ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Your GitHub repo in the form "username/repo-name"
GITHUB_REPO = "your-username/digital-watcher"

# The branch profiles.json lives on (usually "main")
GITHUB_BRANCH = "main"

# Your cron-job.org API key (Console -> Settings -> API)
CRONJOB_API_KEY = "your-cron-job-org-api-key"
